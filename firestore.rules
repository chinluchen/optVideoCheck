rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admin-only access for everything (server-side via firebase-admin bypasses this anyway)
    // But we define it for clarity and future client-side needs
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "chinlu0322@gmail.com");
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /steps/{stepId} {
      allow read: if true; // Publicly readable for the app
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.studentUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /transcriptions/{transcriptionId} {
      allow read, write: if isAdmin();
    }
  }
}
