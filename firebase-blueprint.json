{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users including admins and students",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique login name" },
        "password": { "type": "string", "description": "Login password" },
        "role": { "type": "string", "enum": ["admin", "student"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["username", "password", "role"]
    },
    "Step": {
      "title": "Step",
      "description": "Standard operating steps for optometry experiments",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Step title" },
        "correctAnswer": { "type": "string", "description": "Correct description/answer for the step" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation time" }
      },
      "required": ["title", "correctAnswer"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Student video submission and AI analysis results",
      "type": "object",
      "properties": {
        "studentName": { "type": "string", "description": "Name of the student" },
        "videoUrl": { "type": "string", "description": "URL of the submitted video" },
        "score": { "type": "number", "description": "AI generated score" },
        "result": { "type": "object", "description": "Detailed AI analysis JSON" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission time" }
      },
      "required": ["studentName", "videoUrl", "score", "result"]
    },
    "Transcription": {
      "title": "Transcription",
      "description": "Video transcription status and results",
      "type": "object",
      "properties": {
        "videoUrl": { "type": "string", "description": "URL of the video" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"], "description": "Current status" },
        "transcript": { "type": "string", "description": "Transcribed text" },
        "error": { "type": "string", "description": "Error message if failed" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation time" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time" }
      },
      "required": ["videoUrl", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "/steps/{stepId}": {
      "schema": "Step",
      "description": "Collection of experiment steps"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Collection of student submissions"
    },
    "/transcriptions/{transcriptionId}": {
      "schema": "Transcription",
      "description": "Collection of transcription tasks"
    }
  }
}
